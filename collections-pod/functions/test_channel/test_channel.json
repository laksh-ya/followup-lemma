{
  "name": "test_channel",
  "description": "Send a test email or test notification using the current Settings, for the operator to verify config.",
  "type": "API",
  "code": { "$file": "code.py" },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "pod_config",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "connector", "resource_name": "gmail",
        "permission_ids": ["connector.use"] },
      { "resource_type": "connector", "resource_name": "slack",
        "permission_ids": ["connector.use"] }
    ]
  }
}
