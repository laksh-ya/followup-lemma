{
  "name": "stats_dispatch",
  "description": "Compose and send a collections stats digest to Slack / Telegram / WhatsApp with per-channel metric selection. Modes: manual (send now), test, due (schedule sweep).",
  "type": "API",
  "code": { "$file": "code.py" },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "invoices", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "drafts", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "promises", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "pod_config", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "stats_channels", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "interactions", "permission_ids": ["datastore.table.read", "datastore.record.write"] },
      { "resource_type": "connector", "resource_name": "slack", "permission_ids": ["connector.use"] }
    ]
  }
}
