{
  "name": "seed_demo",
  "description": "One-click demo data: customers + invoices across all stages (deduped by email), then enqueue overdue ones to run the pipeline.",
  "type": "API",
  "code": { "$file": "code.py" },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "clients",
        "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "invoices",
        "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "drafts",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "followup_queue",
        "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "interactions",
        "permission_ids": ["datastore.table.read", "datastore.record.write"] }
    ]
  }
}
