{
  "name": "notify",
  "description": "Send a notification over the configured channel (Slack/WhatsApp) or log it as undelivered if no channel is wired. Never breaks the calling flow.",
  "type": "API",
  "code": { "$file": "code.py" },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "pod_config",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "interactions",
        "permission_ids": ["datastore.table.read", "datastore.record.write"] }
    ]
  }
}
