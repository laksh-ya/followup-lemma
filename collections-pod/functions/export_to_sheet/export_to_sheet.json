{
  "name": "export_to_sheet",
  "description": "Write pod data (invoices, drafts, or the interactions audit log) out to a Google Sheet via the google_sheets connector (delegated, COMPOSIO), so the sheet can be a live mirror of the pod.",
  "type": "API",
  "visibility": "POD",
  "code": { "$file": "code.py" },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "invoices",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "drafts",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "interactions",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "connector", "resource_name": "google_sheets",
        "permission_ids": ["connector.use"] }
    ]
  }
}
