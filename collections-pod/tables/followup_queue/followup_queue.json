{
  "name": "followup_queue",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "invoice_id", "type": "UUID", "required": true,
      "foreign_key": { "references": "invoices.id" } },
    { "name": "reason", "type": "TEXT", "default": "overdue_scan", "max_length": 60,
      "description": "overdue_scan | manual | resend_failed | reply_followup | promise_broken" },
    { "name": "status", "type": "ENUM", "required": true, "default": "QUEUED",
      "options": ["QUEUED", "PROCESSING", "DONE", "ERROR"] },
    { "name": "run_id", "type": "TEXT", "max_length": 80 },
    { "name": "error", "type": "TEXT", "max_length": 1000 }
  ],
  "config": {}
}
