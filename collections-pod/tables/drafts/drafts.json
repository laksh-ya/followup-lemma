{
  "name": "drafts",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "invoice_id", "type": "UUID", "required": true,
      "foreign_key": { "references": "invoices.id" } },
    { "name": "client_id", "type": "UUID", "foreign_key": { "references": "clients.id" } },
    { "name": "stage", "type": "ENUM", "required": true,
      "options": ["PENDING", "STAGE_1", "STAGE_2", "STAGE_3", "STAGE_4", "ESCALATED"] },
    { "name": "tone", "type": "ENUM",
      "options": ["WARM_FRIENDLY", "POLITE_FIRM", "FORMAL_SERIOUS", "STERN_URGENT"] },
    { "name": "channel", "type": "ENUM", "default": "EMAIL", "options": ["EMAIL", "WHATSAPP"] },
    { "name": "subject", "type": "TEXT", "max_length": 300 },
    { "name": "body", "type": "TEXT", "max_length": 6000 },
    { "name": "confidence", "type": "FLOAT", "description": "Agent self-reported (secondary signal)" },
    { "name": "risk_level", "type": "ENUM", "options": ["LOW", "MEDIUM", "HIGH"] },
    { "name": "validation_passed", "type": "BOOLEAN", "default": false },
    { "name": "validation_errors", "type": "JSON" },
    { "name": "fallback_used", "type": "BOOLEAN", "default": false },
    { "name": "status", "type": "ENUM", "required": true, "default": "PENDING_REVIEW",
      "options": ["PENDING_REVIEW", "APPROVED", "AUTO_SENT", "SENT", "REJECTED", "FAILED", "SUPERSEDED"] },
    { "name": "review_reason", "type": "TEXT", "max_length": 120 },
    { "name": "reviewer", "type": "USER" },
    { "name": "reviewer_note", "type": "TEXT", "max_length": 1000 },
    { "name": "edited_by_human", "type": "BOOLEAN", "default": false },
    { "name": "model_used", "type": "TEXT", "max_length": 120 },
    { "name": "tokens_used", "type": "INTEGER" },
    { "name": "latency_ms", "type": "INTEGER" },
    { "name": "sent_at", "type": "DATETIME" },
    { "name": "provider", "type": "TEXT", "max_length": 40 },
    { "name": "provider_message_id", "type": "TEXT", "max_length": 200 },
    { "name": "error_message", "type": "TEXT", "max_length": 1000 }
  ],
  "config": {}
}
