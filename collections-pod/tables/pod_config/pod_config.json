{
  "name": "pod_config",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "singleton", "type": "TEXT", "default": "main", "unique": true,
      "description": "Always 'main' — enforces a single config row" },
    { "name": "auto_dispatch", "type": "BOOLEAN", "default": true },
    { "name": "human_in_loop", "type": "BOOLEAN", "default": true },
    { "name": "review_stage4", "type": "BOOLEAN", "default": true },
    { "name": "review_high_risk", "type": "BOOLEAN", "default": true },
    { "name": "email_enabled", "type": "BOOLEAN", "default": false,
      "description": "false = record only (safe demo); true = actually send via the selected mail_mode" },
    { "name": "mail_mode", "type": "TEXT", "default": "IN_APP",
      "description": "IN_APP | MAILTRAP | RESEND | GMAIL" },
    { "name": "email_from", "type": "TEXT", "default": "Acme Finance <collections@example.com>", "max_length": 200 },
    { "name": "mailtrap_host", "type": "TEXT", "default": "sandbox.smtp.mailtrap.io", "max_length": 120 },
    { "name": "mailtrap_port", "type": "INTEGER", "default": 2525 },
    { "name": "mailtrap_user", "type": "TEXT", "max_length": 120 },
    { "name": "mailtrap_pass", "type": "TEXT", "max_length": 200 },
    { "name": "resend_api_key", "type": "TEXT", "max_length": 200 },
    { "name": "notify_channel", "type": "ENUM", "default": "NONE", "options": ["NONE", "TELEGRAM", "SLACK", "WHATSAPP"] },
    { "name": "telegram_bot_token", "type": "TEXT", "max_length": 200 },
    { "name": "telegram_team_chat_id", "type": "TEXT", "max_length": 80 },
    { "name": "telegram_legal_chat_id", "type": "TEXT", "max_length": 80 },
    { "name": "slack_channel", "type": "TEXT", "max_length": 120 },
    { "name": "slack_legal_channel", "type": "TEXT", "max_length": 120,
      "description": "Slack #legal channel id — legal escalations are auto-posted here" },
    { "name": "slack_account_id", "type": "TEXT", "max_length": 80,
      "description": "Connected Slack connector account id to PIN for posting to shared channels (#legal, #daily-stats) and for the unattended scheduled digest" },
    { "name": "whatsapp_phone_id", "type": "TEXT", "max_length": 80,
      "description": "WhatsApp Business Cloud API phone-number id (Meta Graph)" },
    { "name": "whatsapp_token", "type": "TEXT", "max_length": 400,
      "description": "WhatsApp Business Cloud API access token (Meta Graph)" },
    { "name": "whatsapp_to", "type": "TEXT", "max_length": 40,
      "description": "Default WhatsApp recipient in international format, e.g. 919812345678" },
    { "name": "company_name", "type": "TEXT", "default": "Acme Financial Services", "max_length": 200 },
    { "name": "sender_identity", "type": "TEXT", "default": "Finance team", "max_length": 200 },
    { "name": "finance_lead_member_id", "type": "TEXT", "max_length": 80 },
    { "name": "legal_member_id", "type": "TEXT", "max_length": 80 }
  ],
  "config": {}
}
