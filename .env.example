# ─────────────────────────────────────────────────────────────────────────────
# Collections Agent — environment example
#
# This pod runs ON Lemma, so most "config" lives in the pod itself (the pod_config
# table, editable in the app's Settings). The few things that belong in the
# environment are: the model provider for the agent, optional connector keys, and
# the CLI context used to import/operate the pod.
#
# Local stack values are set with `lemma-stack config set KEY value` (stored in
# ~/.lemma/local/config.toml under [backend.env]); this file documents them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model provider for the drafting agent (REQUIRED) ────────────────────────────
# We use Groq (free, fast, good tool-calling) via the OpenAI-compatible profile.
LEMMA_DEFAULT_MODEL_TYPE=openai_compat
LEMMA_OPENAI_API_KEY=gsk_your_groq_key_here          # console.groq.com  (free, no card)
LEMMA_OPENAI_BASE_URL=https://api.groq.com/openai/v1
LEMMA_OPENAI_DEFAULT_MODEL=llama-3.3-70b-versatile
LEMMA_OPENAI_MODEL_NAMES=llama-3.3-70b-versatile,openai/gpt-oss-120b,llama-3.1-8b-instant
# (Alternatives: anthropic_compat + LEMMA_ANTHROPIC_API_KEY, or Gemini's
#  OpenAI-compatible endpoint. On lemma.work you can run on Lemma credits instead.)

# ── Connectors (OPTIONAL — only if you use Gmail/Slack/WhatsApp via Composio) ────
# Gmail/Slack/WhatsApp surfaces & operations are powered by Composio.
COMPOSIO_API_KEY=
# Secrets-at-rest key for connector credentials (generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRET_ENCRYPTION_KEY=

# ── CLI context (for importing / operating the pod) ─────────────────────────────
# Usually set by `lemma servers select local` + `lemma auth login`; shown for scripts.
LEMMA_ORG_ID=
LEMMA_POD_ID=

# ── In-app channel settings (NO env needed — set these in the app's Settings) ────
# Mail mode (IN_APP | MAILTRAP | RESEND | GMAIL), Mailtrap/Resend creds, Telegram bot
# token + chat ids, Slack channel — all live in the pod_config table and are edited
# in the Settings screen. They are intentionally NOT environment variables so the
# whole product is configurable at runtime without a redeploy.
